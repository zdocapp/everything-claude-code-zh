      "en-US": "---\npaths:\n  - \"**/*.cpp\"\n  - \"**/*.hpp\"\n  - \"**/*.cc\"\n  - \"**/*.hh\"\n  - \"**/*.cxx\"\n  - \"**/*.h\"\n  - \"**/CMakeLists.txt\"\n---",
      "zh-Hans": "---\npaths:\n  - \"**/*.cpp\"\n  - \"**/*.hpp\"\n  - \"**/*.cc\"\n  - \"**/*.hh\"\n  - \"**/*.cxx\"\n  - \"**/*.h\"\n  - \"**/CMakeLists.txt\"\n---"
